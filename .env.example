# Backend (per CORE.md; CORE's shared cross-repo name is BACKEND_API_URL, but Expo
# only inlines client-bundle env vars prefixed EXPO_PUBLIC_, so mobile reads this one)
EXPO_PUBLIC_BACKEND_API_URL=          # e.g. https://api.lively.example.com

# Mock mode (M0.3) — no network at all, serves lib/api/mocks fixtures
EXPO_PUBLIC_USE_MOCKS=                # 1 = on
EXPO_PUBLIC_MOCK_EMPTY=               # 1 = seed a fresh account (no elders) instead of the demo dataset

# Push notifications
EXPO_PUSH_TOKEN_PROJECT_ID=   # Expo project ID for push, or swap for Firebase creds if chosen
